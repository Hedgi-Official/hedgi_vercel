# =============================================================================
# Hedgi — environment variables
# =============================================================================
# Copy to `.env` for local dev; mirror in Vercel Project Settings
# (Production + Preview scopes) for the deployed environment.
# Never commit `.env` itself — only this example file.
# =============================================================================

# --- Required at runtime ---------------------------------------------------

# Postgres connection string. Use the same Neon DB that Replit uses during the
# parallel-running cutover; switch to a fresh DB only after Replit is retired.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Express session cookie signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Do NOT reuse REPL_ID. The app accepts REPL_ID as a legacy fallback so the
# Replit deploy keeps working unchanged during cutover.
SESSION_SECRET=

# Public URL the app is served from. Used to build password-reset links.
# Production: https://hedgi.ai
# Preview: leave unset; the app falls back to req.protocol/host
APP_URL=https://hedgi.ai

# OpenAI API key — powers HedgiBot chat. The OpenAI SDK throws at module
# load time if this is missing, so the function will not boot without it.
OPENAI_API_KEY=

# SMTP for password-reset email (sent from hjalmar@hedgi.ai)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
HEDGI_APP_SECRET=

# External Flask service URL (broker rates, payment brick proxy, trade execution)
FLASK_URL=

# --- Beta access -----------------------------------------------------------

# Comma-separated list of valid invite codes. Used ONLY to seed the
# `invite_codes` table via `npm run db:seed-invite-codes`. After seeding,
# the runtime reads codes from the DB; this var is no longer consulted.
BETA_INVITE_CODES=

# Hardcoded test API key for the HedgiTest user (corporate sandbox).
HEDGI_TEST_API_KEY=

# --- Payments (optional; gated by ENABLE_PAYMENTS) -------------------------

# Set to "true" to enable Mercado Pago integration in this environment
ENABLE_PAYMENTS=false

# Brazil
MP_BR_PUBLIC_KEY=
MP_BR_ACCESS_TOKEN=

# Mexico
MP_MX_PUBLIC_KEY=
MP_MX_ACCESS_TOKEN=

# Legacy fallback (deprecated, but still read by some routes)
MP_ACCESS_TOKEN=

# Public URL for payment-redirect callbacks; falls back to req.protocol/host
PUBLIC_URL=

# --- Vercel-managed (do NOT set manually) ---------------------------------
# VERCEL=1                — set automatically; toggles serverless mode
# VERCEL_URL=...          — set automatically per deployment
# NODE_ENV=production     — set automatically by Vercel
